generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique
  value String
}

model About {
  id      String @id @default(cuid())
  vision  String
  mission String
  history String @default("")
}

model Stat {
  id    String @id @default(cuid())
  key   String @unique
  value String
  label String
  icon  String @default("")
}

model TeamMember {
  id       String  @id @default(cuid())
  name     String
  position String
  category String
  bio      String  @default("")
  imageUrl String  @default("")
  email    String  @default("")
  order    Int     @default(0)
  isActive Boolean @default(true)
  createdAt DateTime @default(now())
}

model Directorate {
  id          String @id @default(cuid())
  name        String
  slug        String @unique
  description String
  goals       String @default("")
  imageUrl    String @default("")
  order       Int    @default(0)
}

model Sponsor {
  id         String   @id @default(cuid())
  name       String
  logoUrl    String   @default("")
  websiteUrl String   @default("")
  category   String   @default("genel")
  order      Int      @default(0)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
}

model News {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  summary     String
  content     String
  imageUrl    String    @default("")
  category    String    @default("genel")
  isPublished Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Event {
  id          String    @id @default(cuid())
  title       String
  slug        String    @unique
  description String
  imageUrl    String    @default("")
  category    String
  date        DateTime?
  location    String    @default("")
  isPublished Boolean   @default(false)
  order       Int       @default(0)
  createdAt   DateTime  @default(now())
}

model Application {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  email     String
  phone     String   @default("")
  school    String   @default("")
  grade     String   @default("")
  message   String   @default("")
  status    String   @default("beklemede")
  createdAt DateTime @default(now())
}

model Publication {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  fileUrl     String   @default("")
  imageUrl    String   @default("")
  category    String   @default("genel")
  isPublished Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model PressIdentity {
  id          String @id @default(cuid())
  title       String
  description String @default("")
  fileUrl     String @default("")
  category    String @default("logo")
}

model Contact {
  id        String @id @default(cuid())
  address   String @default("")
  email     String @default("")
  phone     String @default("")
  mapUrl    String @default("")
  instagram String @default("")
  twitter   String @default("")
  linkedin  String @default("")
  youtube   String @default("")
}
